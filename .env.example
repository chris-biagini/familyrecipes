# Server
PORT=3030
BINDING=0.0.0.0
RAILS_MAX_THREADS=3

# Rails
SECRET_KEY_BASE=
RAILS_LOG_LEVEL=info

# Host authorization (production) — comma-separated domain(s)
# Prevents DNS rebinding attacks. Omit to allow all hosts.
# ALLOWED_HOSTS=recipes.example.com

# Active Record Encryption (required in production — protects encrypted columns)
# Generate with: bin/rails db:encryption:init
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

# Nutrition data (optional — for USDA API lookups)
# USDA_API_KEY=
