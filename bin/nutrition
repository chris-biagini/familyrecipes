#!/usr/bin/env ruby
# frozen_string_literal: true

# CLI entry point for the nutrition catalog TUI. Dispatches to the RatatuiRuby
# TUI for interactive editing of ingredient-catalog.yaml, with a non-TUI
# --coverage mode for quick terminal reports. Accepts an optional ingredient
# name argument to jump directly to its detail screen.
#
# Collaborators:
# - NutritionTui::App (TUI event loop and screen management)
# - NutritionTui::Data (data I/O, coverage analysis — used by --coverage)

require 'bundler/setup'

if ARGV.include?('--help') || ARGV.include?('-h')
  puts 'Usage:'
  puts '  bin/nutrition                        Dashboard TUI'
  puts '  bin/nutrition "Cream cheese"         Jump to ingredient detail'
  puts '  bin/nutrition --coverage             Coverage report (no TUI)'
  puts ''
  puts 'Requires USDA_API_KEY in .env or environment (except --coverage).'
  puts '  Free key: https://fdc.nal.usda.gov/api-key-signup'
  exit 0
end

if ARGV.include?('--coverage')
  require_relative '../lib/nutrition_tui/data'
  require 'tty-table'
  require 'pastel'
  include NutritionTui::Data # rubocop:disable Style/MixinUsage

  PASTEL = Pastel.new

  def print_top_missing(missing_names, recipes_map, limit: 15)
    return if missing_names.empty?

    puts PASTEL.bold("\nTop missing (by recipe count):")
    missing_names.first(limit).each do |name|
      puts "  #{name} (#{recipes_map[name].uniq.size} recipes)"
    end
  end

  def run_coverage_mode
    nutrition_data = load_nutrition_data
    ctx = load_context

    result = find_missing_ingredients(nutrition_data, ctx)
    missing = result[:missing]
    recipes_map = result[:ingredients_to_recipes]

    total = recipes_map.size
    missing_count = missing.size
    found = total - missing_count
    omitted = nutrition_data.count { |_, e| e['omit_from_shopping'] }

    resolvable_map = count_resolvable(nutrition_data, ctx)
    resolvable = resolvable_map.count { |_, v| v }

    puts PASTEL.bold("\nIngredient Coverage Report")

    rows = [
      ['Total unique ingredients', total.to_s],
      ['Catalog entries found', "#{found} (#{format_pct(found, total)})"],
      ['Fully resolvable', "#{resolvable} (#{format_pct(resolvable, total)})"],
      ['Missing entirely', "#{missing_count} (#{format_pct(missing_count, total)})"],
      ['Omitted', omitted.to_s]
    ]

    table = TTY::Table.new(rows: rows)
    puts table.render(:basic, padding: [0, 2, 0, 2])

    print_top_missing(missing, recipes_map)
  end

  run_coverage_mode
  exit 0
end

require_relative '../lib/nutrition_tui'

ingredient_name = ARGV.reject { |a| a.start_with?('-') }.first
NutritionTui::App.new(jump_to: ingredient_name).run
