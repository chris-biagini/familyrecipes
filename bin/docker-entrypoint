#!/bin/bash
#
# Docker container entry point. Prepares the database, syncs the ingredient
# catalog, seeds sample data (first boot only), then execs the CMD (typically
# Puma).
# All operations are idempotent — safe to run on every container start.
set -e

# Auto-generate SECRET_KEY_BASE when not provided via environment.
# Persists to storage volume so sessions survive container restarts.
if [ -z "$SECRET_KEY_BASE" ]; then
  if [ ! -f storage/.secret_key_base ]; then
    echo "Generating secret key..."
    ruby -rsecurerandom -e 'print SecureRandom.hex(64)' > storage/.secret_key_base
    chmod 600 storage/.secret_key_base
  fi
  export SECRET_KEY_BASE=$(cat storage/.secret_key_base)
fi

# Auto-generate Active Record Encryption keys when not provided.
# Persists to storage volume so encrypted data survives container restarts.
for var in ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY \
           ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY \
           ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT; do
  if [ -z "${!var}" ]; then
    keyfile="storage/.${var,,}"
    if [ ! -f "$keyfile" ]; then
      echo "Generating ${var}..."
      ruby -rsecurerandom -e 'print SecureRandom.hex(32)' > "$keyfile"
      chmod 600 "$keyfile"
    fi
    export "$var=$(cat "$keyfile")"
  fi
done

echo "Preparing database..."
bin/rails db:prepare

echo "Syncing ingredient catalog..."
bin/rails catalog:sync

echo "Seeding data..."
bin/rails db:seed

echo "Starting server..."
exec "$@"
