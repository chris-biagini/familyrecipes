// Minimal service worker — exists solely to satisfy the PWA install requirement
// on iOS Safari. No caching, no fetch interception. The browser handles all
// requests normally. Served via PwaController with Cache-Control: no-cache.
self.addEventListener('install', function() { self.skipWaiting() })
self.addEventListener('activate', function(event) {
  event.waitUntil(
    caches.keys().then(function(names) {
      return Promise.all(names.map(function(name) { return caches.delete(name) }))
    }).then(function() {
      return self.clients.claim()
    })
  )
})
