<%# Graphical (form-based) Quick Bites editor. Rendered inside the editor dialog
    alongside the plaintext textarea; the quickbites_editor coordinator toggles
    visibility between them. All category cards are built dynamically by the
    quickbites_graphical_controller — categoriesContainer starts empty. %>
<div data-controller="quickbites-graphical">
  <div class="graphical-form">
    <div class="graphical-field-group">
      <div class="graphical-section-header">
        <span class="graphical-label">Categories</span>
        <button type="button" class="graphical-btn--add-step"
                data-action="click->quickbites-graphical#addCategory">+ Add Category</button>
      </div>
      <div data-quickbites-graphical-target="categoriesContainer"></div>
    </div>
  </div>
</div>
