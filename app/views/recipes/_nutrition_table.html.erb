<aside class="nutrition-facts">
  <h2>Nutrition Facts</h2>
  <% columns = nutrition_columns(nutrition) %>
  <table>
    <thead>
      <tr>
        <th></th>
        <%- columns.each do |label, _, _| -%>
        <th><%= label %></th>
        <%- end -%>
      </tr>
    </thead>
    <tbody>
      <%- RecipesHelper::NUTRITION_ROWS.each do |label, key, unit_label, indent| -%>
      <tr<%= %( class="indent-#{indent}").html_safe if indent > 0 %>>
        <td><%= label %></td>
        <%- columns.each do |_, values, is_scalable| -%>
        <td<%= %( data-nutrient="#{key}" data-base-value="#{values[key].to_f.round(1)}" data-unit="#{unit_label}").html_safe if is_scalable %>><%= values[key].to_f.round %><%= unit_label %></td>
        <%- end -%>
      </tr>
      <%- end -%>
    </tbody>
  </table>
  <% missing = nutrition_missing_ingredients(nutrition) %>
  <%- if missing.any? -%>
  <p class="nutrition-note">*Approximate. Data unavailable for: <%= missing.join(', ') %>.</p>
  <%- end -%>
</aside>
