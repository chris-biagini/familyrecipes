<%# locals: (recipe:, nutrition:) %>
<div id="recipe-content">
  <article class="recipe" data-controller="wake-lock recipe-state scale-panel">
    <header>
      <h1><%= recipe.title %></h1>
      <%- if recipe.description.present? -%>
      <p><%= recipe.description %></p>
      <%- end -%>
      <p class="recipe-meta">
        <span><%= link_to recipe.category.name, home_path(anchor: recipe.category.slug) %></span>
        <%- if recipe.makes_quantity -%>
        <span>&middot;</span>
        <%- if nutrition&.dig('makes_unit_singular') -%>
        <span>Makes <%= format_yield_with_unit(format_makes(recipe), nutrition['makes_unit_singular'], nutrition['makes_unit_plural']) %></span>
        <%- else -%>
        <span>Makes <%= format_yield_line(format_makes(recipe)) %></span>
        <%- end -%>
        <%- end -%>
        <%- if recipe.serves -%>
        <span>&middot;</span>
        <span>Serves <%= format_yield_line(recipe.serves.to_s) %></span>
        <%- end -%>
      </p>
      <% if recipe.tags.any? %>
        <p class="recipe-tags">
          <% recipe.tags.sort_by(&:name).each do |tag| %>
            <% smart = smart_tag_pill_attrs(tag.name) %>
            <button type="button"
                    class="recipe-tag-pill tag-pill tag-pill--tag <%= smart.dig(:class)&.join(' ') %>"
                    data-action="click->recipe-state#searchTag"
                    data-tag="<%= tag.name %>"><% if smart.dig(:data, :smart_emoji) %><span class="smart-icon<%= ' smart-icon--crossout' if smart.dig(:class)&.include?('tag-pill--crossout') %>"><%= smart.dig(:data, :smart_emoji) %></span><% end %><%= tag.name %></button>
          <% end %>
        </p>
      <% end %>
      <div class="scale-bar" data-scale-panel-target="panel">
        <div class="recipe-actions">
          <%- if current_member? -%>
          <button type="button" id="edit-button" class="btn-ghost">
            <svg width="12" height="12" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4l6 6-16 16H6v-6z"/><line x1="18" y1="8" x2="24" y2="14"/></svg>
            Edit
          </button>
          <span class="recipe-actions-dot">&middot;</span>
          <%- end -%>
          <a href="#" class="scale-toggle" data-scale-panel-target="toggle" data-action="click->scale-panel#toggle:prevent">Scale</a>
        </div>
        <div class="scale-controls" data-scale-panel-target="inner" aria-hidden="true">
          <div class="scale-controls-inner">
            <div class="scale-controls-center">
              <div class="scale-presets">
                <button type="button" class="btn btn-sm scale-preset" data-scale-panel-target="preset" data-action="scale-panel#selectPreset">&frac12;&times;</button>
                <button type="button" class="btn btn-sm scale-preset active" data-scale-panel-target="preset" data-action="scale-panel#selectPreset">1&times;</button>
                <button type="button" class="btn btn-sm scale-preset" data-scale-panel-target="preset" data-action="scale-panel#selectPreset">2&times;</button>
                <button type="button" class="btn btn-sm scale-preset" data-scale-panel-target="preset" data-action="scale-panel#selectPreset">3&times;</button>
              </div>
              <span class="scale-divider"></span>
              <div class="scale-input-group">
                <input type="text" class="input-base input-sm scale-input" data-scale-panel-target="input" data-action="input->scale-panel#onInput" value="1" placeholder="e.g. 3/2" inputmode="text" autocomplete="off">
                <button type="button" class="btn-ghost btn-sm scale-reset" data-scale-panel-target="reset" data-action="scale-panel#reset" hidden>Reset</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </header>

    <% ingredient_info = nutrition&.slice('ingredient_details', 'missing_ingredients', 'partial_ingredients') %>
    <% recipe.steps.each do |step| %>
      <%= render 'recipes/step', step: step, embedded: false, heading_level: 2, scale_factor: 1.0, ingredient_info: ingredient_info %>
    <% end %>

    <%- if recipe.footer.present? -%>
    <footer>
      <%= render_markdown(recipe.footer) %>
    </footer>
    <%- end -%>

    <%- if current_kitchen.show_nutrition && nutrition && nutrition['totals']&.values&.any? { |v| v.to_f > 0 } -%>
      <%= render 'recipes/nutrition_table', nutrition: nutrition %>
    <%- end -%>
  </article>
</div>
