<%# Minimal layout for auth pages (create kitchen, join, etc.).
    Shares design tokens from base.css but skips navigation, editor
    infrastructure, and settings dialog. Used by KitchensController
    and JoinsController. %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
  <meta name="theme-color" content="#faf8f5" media="(prefers-color-scheme: light)">
  <meta name="theme-color" content="#1e1b18" media="(prefers-color-scheme: dark)">
  <title><%= yield(:title).presence || 'mirepoix' %></title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag 'base', 'auth' %>
  <link rel="icon" type="image/svg+xml" href="<%= asset_path('favicon.svg') %>">
</head>
<body class="auth-page">
  <main class="auth-container">
    <%= yield %>
  </main>
</body>
</html>
