<nav data-controller="nav-menu"
     data-action="keydown.esc@document->nav-menu#close click@document->nav-menu#closeOutside turbo:before-visit@document->nav-menu#close">
  <div data-nav-menu-target="container">
    <button type="button" class="hamburger-btn"
            data-nav-menu-target="button"
            data-action="nav-menu#toggle"
            aria-label="Menu" aria-expanded="false">
      <svg class="hamburger-icon" viewBox="0 0 24 24" aria-hidden="true">
        <rect class="hamburger-top" x="3" y="11" width="18" height="2" rx="1" fill="currentColor"/>
        <rect class="hamburger-mid" x="3" y="11" width="18" height="2" rx="1" fill="currentColor"/>
        <rect class="hamburger-bot" x="3" y="11" width="18" height="2" rx="1" fill="currentColor"/>
      </svg>
    </button>
    <div class="nav-links" data-nav-menu-target="navLinks">
      <%= render 'shared/nav_links' %>
    </div>
  </div>
  <div class="nav-drawer" data-nav-menu-target="drawer" aria-hidden="true">
    <div class="nav-drawer-inner">
      <%= render 'shared/nav_links' %>
    </div>
  </div>
  <%= yield :extra_nav if content_for?(:extra_nav) %>
  <% if current_kitchen %>
    <button type="button" class="nav-icon-btn"
            data-action="search-overlay#open"
            title="Search recipes (press /)"
            aria-label="Search recipes">
      <%= icon(:search, class: 'nav-icon', size: nil) %>
    </button>
  <% end %>
  <% if logged_in? %>
    <button type="button" id="settings-button" class="nav-icon-btn" title="Settings" aria-label="Settings">
      <%= icon(:settings, class: 'nav-icon', size: nil) %>
    </button>
  <% end %>
  <% if content_for?(:help_path) %>
    <a href="<%= help_url(yield(:help_path)) %>"
       class="nav-icon-btn"
       title="Help"
       aria-label="Help"
       target="_blank"
       rel="noopener noreferrer">
      <%= icon(:help, class: 'nav-icon', size: nil) %>
    </a>
  <% end %>
</nav>
