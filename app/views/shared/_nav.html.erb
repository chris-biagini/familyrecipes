<nav data-controller="nav-menu"
     data-action="keydown.esc@document->nav-menu#close click@document->nav-menu#closeOutside turbo:before-visit@document->nav-menu#close">
  <div data-nav-menu-target="container">
    <button type="button" class="hamburger-btn"
            data-nav-menu-target="button"
            data-action="nav-menu#toggle"
            aria-label="Menu" aria-expanded="false">
      <svg class="hamburger-icon" viewBox="0 0 24 24" aria-hidden="true">
        <rect class="hamburger-top" x="3" y="11" width="18" height="2" rx="1" fill="currentColor"/>
        <rect class="hamburger-mid" x="3" y="11" width="18" height="2" rx="1" fill="currentColor"/>
        <rect class="hamburger-bot" x="3" y="11" width="18" height="2" rx="1" fill="currentColor"/>
      </svg>
    </button>
    <div class="nav-links" data-nav-menu-target="navLinks">
      <%= render 'shared/nav_links' %>
    </div>
  </div>
  <div class="nav-drawer" data-nav-menu-target="drawer" aria-hidden="true">
    <div class="nav-drawer-inner">
      <%= render 'shared/nav_links' %>
    </div>
  </div>
  <% if logged_in? %>
    <%= link_to settings_path, class: 'nav-settings-link', title: 'Settings', aria: { label: 'Settings' } do %>
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="3"/>
        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
      </svg>
    <% end %>
  <% end %>
  <%= yield :extra_nav if content_for?(:extra_nav) %>
</nav>
