<%# locals: (name:, grams:) %>
<div class="editor-portion-row" data-nutrition-editor-target="portionRow">
  <input type="text" class="input-base"
         value="<%= name == '~unitless' ? 'each' : name %>"
         placeholder="e.g. stick, slice, each"
         data-nutrition-editor-target="portionName"
         aria-label="Portion name">
  <span class="editor-portion-eq">=</span>
  <input type="number" class="input-base input-sm"
         value="<%= format_nutrient_value(grams) %>"
         inputmode="decimal" step="any" min="0"
         data-nutrition-editor-target="portionGrams"
         aria-label="Portion grams">
  <span class="editor-portion-unit">g</span>
  <button type="button" class="editor-btn-icon" aria-label="Remove portion"
          data-action="click->nutrition-editor#removePortion">&times;</button>
</div>
