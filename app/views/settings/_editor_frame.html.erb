<%# locals: (kitchen:, owner:, members:, current_user_record:) %>
<turbo-frame id="settings-editor-frame">
  <div class="editor-body">
    <div class="editor-form">
      <fieldset class="editor-section">
        <legend class="editor-section-title">Site</legend>
        <div class="settings-field">
          <label for="settings-site-title">Site title</label>
          <input type="text" id="settings-site-title" class="input-base input-lg"
                 data-settings-editor-target="siteTitle"
                 value="<%= kitchen.site_title %>">
        </div>
        <div class="settings-field">
          <label for="settings-homepage-heading">Homepage heading</label>
          <input type="text" id="settings-homepage-heading" class="input-base input-lg"
                 data-settings-editor-target="homepageHeading"
                 value="<%= kitchen.homepage_heading %>">
        </div>
        <div class="settings-field">
          <label for="settings-homepage-subtitle">Homepage subtitle</label>
          <input type="text" id="settings-homepage-subtitle" class="input-base input-lg"
                 data-settings-editor-target="homepageSubtitle"
                 value="<%= kitchen.homepage_subtitle %>">
        </div>
      </fieldset>

      <fieldset class="editor-section">
        <legend class="editor-section-title">Recipes</legend>
        <div class="settings-field">
          <label class="settings-checkbox-label">
            <input type="checkbox" id="settings-show-nutrition"
                   data-settings-editor-target="showNutrition"
                   <%= 'checked' if kitchen.show_nutrition %>>
            Display nutrition information under recipes
          </label>
        </div>
        <div class="settings-field">
          <label class="settings-checkbox-label">
            <input type="checkbox" id="settings-decorate-tags"
                   data-settings-editor-target="decorateTags"
                   <%= 'checked' if kitchen.decorate_tags %>>
            Decorate special tags
          </label>
          <span class="settings-field-hint">Show emoji and colors for dietary, cuisine, and other recognized tags</span>
        </div>
      </fieldset>

      <fieldset class="editor-section">
        <legend class="editor-section-title">API Keys</legend>
        <div class="settings-field" data-controller="reveal">
          <label for="settings-usda-api-key">USDA API key</label>
          <div class="settings-api-key-row">
            <input type="password" id="settings-usda-api-key" class="input-base input-lg"
                   autocomplete="off"
                   data-settings-editor-target="usdaApiKey"
                   data-reveal-target="input"
                   placeholder="<%= kitchen.usda_api_key.present? ? 'Key set — enter new key to change' : '' %>">
            <button type="button" class="btn settings-reveal-btn"
                    data-action="reveal#toggle"
                    data-reveal-target="button">Show</button>
          </div>
        </div>
        <div class="settings-field" data-controller="reveal">
          <label for="settings-anthropic-api-key">Anthropic API key</label>
          <div class="settings-api-key-row">
            <input type="password" id="settings-anthropic-api-key" class="input-base input-lg"
                   autocomplete="off"
                   data-settings-editor-target="anthropicApiKey"
                   data-reveal-target="input"
                   placeholder="<%= kitchen.anthropic_api_key.present? ? 'Key set — enter new key to change' : '' %>">
            <button type="button" class="btn settings-reveal-btn"
                    data-action="reveal#toggle"
                    data-reveal-target="button">Show</button>
          </div>
        </div>
      </fieldset>

      <fieldset class="editor-section">
        <legend class="editor-section-title">Kitchen</legend>
        <div class="settings-field">
          <label>Join code</label>
          <div class="settings-join-code-row">
            <input type="text" class="input-base input-lg" readonly
                   value="<%= kitchen.join_code %>"
                   data-settings-editor-target="joinCode">
            <% if owner %>
              <button type="button" class="btn"
                      data-action="settings-editor#regenerateJoinCode"
                      data-settings-editor-target="regenerateButton">Regenerate</button>
            <% end %>
          </div>
          <span class="settings-field-hint">Share this code with people you want to invite to your kitchen.</span>
        </div>
        <div class="settings-field">
          <label>Members</label>
          <ul class="settings-members-list">
            <% members.each do |member| %>
              <li>
                <span class="member-name"><%= member[:name] %></span>
                <span class="member-email"><%= member[:email] %></span>
                <% if member[:role] == 'owner' %>
                  <span class="member-role">owner</span>
                <% end %>
              </li>
            <% end %>
          </ul>
        </div>
      </fieldset>

      <fieldset class="editor-section">
        <legend class="editor-section-title">Your Profile</legend>
        <div class="settings-field">
          <label for="settings-profile-name">Name</label>
          <input type="text" id="settings-profile-name" class="input-base input-lg"
                 data-settings-editor-target="profileName"
                 value="<%= current_user_record.name %>">
        </div>
        <div class="settings-field">
          <label for="settings-profile-email">Email</label>
          <input type="email" id="settings-profile-email" class="input-base input-lg"
                 data-settings-editor-target="profileEmail"
                 value="<%= current_user_record.email %>">
        </div>
      </fieldset>
    </div>
  </div>
</turbo-frame>
